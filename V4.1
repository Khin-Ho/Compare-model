import os
import numpy as np
import pandas as pd
from sklearn.model_selection import train_test_split, GridSearchCV, cross_val_score
from sklearn.preprocessing import StandardScaler
from sklearn.feature_selection import SelectKBest, f_regression
from sklearn.linear_model import Ridge
from sklearn.neighbors import KNeighborsRegressor
from sklearn.svm import SVR
from sklearn.tree import DecisionTreeRegressor
from sklearn.ensemble import RandomForestRegressor, StackingRegressor
from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score
import joblib as jl

# ====================== 配置 ======================
DATA_PATH = r"E:\桌面\3\ML_ready\HIX.csv"
SAVE_FOLDER = r"E:\桌面\3\ML_ready"
JOBLIB_TEMP = r"C:\Temp\joblib_temp"
CV_FOLDS = 5
TEST_SIZE = 0.3

os.makedirs(SAVE_FOLDER, exist_ok=True)
os.makedirs(JOBLIB_TEMP, exist_ok=True)
os.environ["JOBLIB_TEMP_FOLDER"] = JOBLIB_TEMP  # Joblib 临时目录避免中文路径

# ====================== 读取数据 ======================
df = pd.read_csv(DATA_PATH, encoding="utf-8-sig")
print("📂 读取数据列名：", df.columns.tolist())

# ====================== 特征选择 ======================
X = df[["PS", "KOH", "Microwave", "R1", "R2", "R3", "R4", "R5"]].values
y = df["HIX_normalized"].values

# 标准化
scaler = StandardScaler()
X = scaler.fit_transform(X)

# SelectKBest
selector = SelectKBest(score_func=f_regression, k='all')
X_selected = selector.fit_transform(X, y)
selected_features = [f for f, s in zip(["PS", "KOH", "Microwave", "R1", "R2", "R3", "R4", "R5"], selector.scores_)]
print("Selected features:", selected_features)

# ====================== 数据集划分 ======================
X_train, X_test, y_train, y_test = train_test_split(X_selected, y, test_size=TEST_SIZE, random_state=42)
print("数据集划分： X_train:", X_train.shape, "X_test:", X_test.shape, "y:", y.shape)

# ====================== 模型与超参数 ======================
models = {
    "Ridge": {
        "model": Ridge(),
        "params": {"alpha": [0.1, 1, 10, 100]}
    },
    "KNN": {
        "model": KNeighborsRegressor(),
        "params": {"n_neighbors": [3, 5, 7, 9, 11], "weights": ["uniform", "distance"]}
    },
    "SVR": {
        "model": SVR(),
        "params": {"C": [0.1, 1, 10], "epsilon": [0.1, 0.2], "kernel": ["linear", "rbf"]}
    },
    "DT": {
        "model": DecisionTreeRegressor(),
        "params": {"max_depth": [3, 5, 10], "min_samples_split": [2, 5, 10]}
    },
    "RF": {
        "model": RandomForestRegressor(),
        "params": {"n_estimators": [100, 200], "max_depth": [5, 10], "min_samples_leaf": [1, 2, 4]}
    }
}


# ====================== 模型训练函数 ======================
def train_model(name, model, params, X_train, y_train, X_test, y_test):
    # GridSearchCV n_jobs=1 避免 Joblib 中文路径问题
    grid = GridSearchCV(model, params, cv=CV_FOLDS, scoring='r2', n_jobs=1)
    grid.fit(X_train, y_train)
    best_model = grid.best_estimator_

    # 训练集预测
    y_train_pred = best_model.predict(X_train)
    train_r2 = r2_score(y_train, y_train_pred)
    train_mse = mean_squared_error(y_train, y_train_pred)
    train_mae = mean_absolute_error(y_train, y_train_pred)

    # 测试集预测
    y_test_pred = best_model.predict(X_test)
    test_r2 = r2_score(y_test, y_test_pred)
    test_mse = mean_squared_error(y_test, y_test_pred)
    test_mae = mean_absolute_error(y_test, y_test_pred)

    # 交叉验证 R²
    cv_r2 = cross_val_score(best_model, X_train, y_train, cv=CV_FOLDS, scoring='r2', n_jobs=1)

    # 保存模型
    jl.dump(best_model, os.path.join(SAVE_FOLDER, f"{name}_model.pkl"))

    # 打印
    print(f"\n{name} 最优参数: {grid.best_params_}")
    print(f"{name} Train R2: {train_r2:.4f}, Test R2: {test_r2:.4f}, CV R2 mean: {cv_r2.mean():.4f}")

    return {
        "Model": name,
        "Train_R2": train_r2,
        "Test_R2": test_r2,
        "Train_MSE": train_mse,
        "Test_MSE": test_mse,
        "Train_MAE": train_mae,
        "Test_MAE": test_mae,
        "CV_R2_mean": cv_r2.mean()
    }, best_model


# ====================== 训练所有模型 ======================
results = []
fitted_models = {}
for name, mp in models.items():
    res, model_fit = train_model(name, mp["model"], mp["params"], X_train, y_train, X_test, y_test)
    results.append(res)
    fitted_models[name] = model_fit

# ====================== 稳定 Stacking 集成 ======================
# 选前3个模型作为 base
top_models_names = sorted(results, key=lambda x: x["CV_R2_mean"], reverse=True)[:3]
top_models = [(r["Model"], fitted_models[r["Model"]]) for r in top_models_names]

stack = StackingRegressor(
    estimators=top_models,
    final_estimator=Ridge(),
    n_jobs=1
)
stack.fit(X_train, y_train)

y_train_pred = stack.predict(X_train)
y_test_pred = stack.predict(X_test)
train_r2 = r2_score(y_train, y_train_pred)
test_r2 = r2_score(y_test, y_test_pred)
train_rmse = mean_squared_error(y_train, y_train_pred, squared=False)
test_rmse = mean_squared_error(y_test, y_test_pred, squared=False)

jl.dump(stack, os.path.join(SAVE_FOLDER, "Stacking_model.pkl"))

results.append({
    "Model": "Stacking",
    "Train_R2": train_r2,
    "Test_R2": test_r2,
    "Train_RMSE": train_rmse,
    "Test_RMSE": test_rmse
})

# ====================== 保存性能汇总 ======================
results_df = pd.DataFrame(results)
results_df.to_csv(os.path.join(SAVE_FOLDER, "model_performance_summary.csv"), index=False)
print("\n📊 模型性能汇总：")
print(results_df)
print(f"\n✅ 全部模型和结果已保存到 {SAVE_FOLDER}")
